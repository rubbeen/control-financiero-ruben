{
  "name": "control-financiero-ruben",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "cap:init": "npx cap init \"Control Financiero Ruben\" com.ruben.controlfinanciero --web-dir=dist",
